@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>Welcome back</h1>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert-error">@error</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="email" placeholder="you@example.com" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="password" />
        </div>

        <button class="btn-primary full-width" @onclick="DoLogin" disabled="@isLoading">
            @(isLoading ? "Logging in…" : "Log in")
        </button>

        <p class="auth-link">Don't have an account? <a href="/register">Register</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string error = string.Empty;
    private bool isLoading = false;

    private async Task DoLogin()
    {
        error = string.Empty;
        isLoading = true;
        try
        {
            var result = await Api.LoginAsync(new CookingApp.Core.DTOs.LoginRequest(email, password));
            Auth.Login(result.Token, result.UserId, result.DisplayName);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        isLoading = false;
    }
}
