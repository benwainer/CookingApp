@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>CookingApp — Discover Recipes</PageTitle>

<div class="home-hero">
    <h1>What are you cooking today?</h1>
    <p class="hero-sub">Search by country, ingredient, flavour, or category.</p>

    <!-- ── Autocomplete Search Bar ───────────────────────────────────────── -->
    <div class="search-bar-wrapper">
        <input class="search-input"
               placeholder="Try &quot;India&quot;, &quot;Chicken Breast&quot;, &quot;Spicy&quot;…"
               @bind="searchQuery"
               @bind:event="oninput"
               @bind:after="FetchSuggestionsAsync"
               @onkeydown="OnKeyDown" />
        <button class="search-btn" @onclick="DoSearch">Search</button>

        @if (suggestions.Count > 0)
        {
            <ul class="autocomplete-dropdown">
                @foreach (var s in suggestions)
                {
                    var item = s; // capture for lambda
                    <li @onclick="() => SelectSuggestion(item)">
                        <span class="suggestion-type">@item.Type</span>
                        @item.Value
                    </li>
                }
            </ul>
        }
    </div>

    <!-- ── Browse Tiles ──────────────────────────────────────────────────── -->
    <div class="browse-section">
        <h2>Browse by</h2>
        <div class="browse-tiles">
            <div class="browse-tile" @onclick='() => BrowseByCategory("Breakfast")'>
                <span class="tile-icon">🌅</span>
                <span>Breakfast</span>
            </div>
            <div class="browse-tile" @onclick='() => BrowseByCategory("Snack")'>
                <span class="tile-icon">🥨</span>
                <span>Snack</span>
            </div>
            <div class="browse-tile" @onclick='() => BrowseByCategory("Starter")'>
                <span class="tile-icon">🥗</span>
                <span>Starter</span>
            </div>
            <div class="browse-tile" @onclick='() => BrowseByCategory("Main")'>
                <span class="tile-icon">🍽️</span>
                <span>Main Course</span>
            </div>
            <div class="browse-tile" @onclick='() => BrowseByCategory("Dessert")'>
                <span class="tile-icon">🍰</span>
                <span>Dessert</span>
            </div>
        </div>

        <h2>Browse by flavour</h2>
        <div class="flavor-chips">
            @foreach (var flavor in new[] { "spicy", "sweet", "sour", "bitter", "savory", "crispy", "aromatic" })
            {
                var f = flavor;
                <button class="flavor-chip @(selectedFlavors.Contains(f) ? "active" : "")"
                        @onclick="() => ToggleFlavor(f)">
                    @FlavorEmoji(f) @f
                </button>
            }
        </div>
        @if (selectedFlavors.Count > 0)
        {
            <button class="btn-primary" @onclick="BrowseByFlavor">
                Show @string.Join(" + ", selectedFlavors) recipes →
            </button>
        }
    </div>
</div>
